# ── Required ──────────────────────────────────────────────────────────────────
# Groq API key — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search API key — https://tavily.com (free: 1000 searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# GitHub Personal Access Token (read:repo scope) — https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Groq model override (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# LLM sampling parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# MCP timeout overrides (seconds)
MCP_INIT_TIMEOUT=30
MCP_CALL_TIMEOUT=60

# Search depth controls
MAX_SEARCH_RESULTS=10
MAX_SCRAPE_ARTICLES=5
MAX_GITHUB_REPOS=10

# FastAPI server (Render sets PORT automatically)
API_HOST=0.0.0.0
PORT=8000

# Scheduler — weekday hour/minute in UTC for always-on reports (default: Mon 08:00)
SCHEDULER_CRON_HOUR=8
SCHEDULER_CRON_MINUTE=0

# Comma-separated list of topics for the always-on background agent
DEFAULT_TOPICS=OpenAI competitors,Anthropic Claude,AI agent frameworks
